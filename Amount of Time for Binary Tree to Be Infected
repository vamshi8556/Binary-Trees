/**
 * Definition for a binary tree node.
 * public class TreeNode {
 *     int val;
 *     TreeNode left;
 *     TreeNode right;
 *     TreeNode() {}
 *     TreeNode(int val) { this.val = val; }
 *     TreeNode(int val, TreeNode left, TreeNode right) {
 *         this.val = val;
 *         this.left = left;
 *         this.right = right;
 *     }
 * }
 */
class Solution {
    HashMap<Integer, TreeNode> map = new HashMap<>();
    TreeNode infect;
    public void findinfected(TreeNode root, int val, TreeNode par){
        if(root == null){
            return ;
        }
        map.put(root.val,par);
        if(root.val == val){
            infect = root;
        }
        findinfected(root.left, val, root);
        findinfected(root.right, val, root);
    }
    public int amountOfTime(TreeNode root, int start) {
        findinfected(root,start,null);
        int time = -1;
        HashSet<Integer> visit = new HashSet<>();
        LinkedList<TreeNode> q = new LinkedList<>();
        q.addLast(infect);
        while(q.size() != 0){
            int size = q.size();
            while(size != 0){
                TreeNode rem = q.removeFirst();
                visit.add(rem.val);
                TreeNode pare = map.get(rem.val);
                if(pare != null && !visit.contains(pare.val)){
                    q.addLast(pare);
                }
                if(rem.left != null && !visit.contains(rem.left.val)){
                    q.addLast(rem.left);
                }
                if(rem.right != null && !visit.contains(rem.right.val)){
                    q.addLast(rem.right);
                }
                size--;
            }
            time++;
        }
        return time;
    }
}

