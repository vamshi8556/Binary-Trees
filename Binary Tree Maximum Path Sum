/**
 * Definition for a binary tree node.
 * public class TreeNode {
 *     int val;
 *     TreeNode left;
 *     TreeNode right;
 *     TreeNode() {}
 *     TreeNode(int val) { this.val = val; }
 *     TreeNode(int val, TreeNode left, TreeNode right) {
 *         this.val = val;
 *         this.left = left;
 *         this.right = right;
 *     }
 * }
 */
class Solution {
    int omax = Integer.MIN_VALUE;
    public int height(TreeNode root){
        if(root == null){
            return -1000;
        }
        int lsum = height(root.left);
        int rsum = height(root.right);
        int p1 = lsum + root.val;
        int p2 = rsum + root.val;
        int p3 = lsum + root.val + rsum;
        int p4 = root.val;
        int max = Math.max(Math.max(p1,p2),Math.max(p3,p4));
        if(max > omax){
            omax = max;
        }
        return Math.max(Math.max(p1,p2),p4);
    }
    public int maxPathSum(TreeNode root) {
        height(root);
        return omax;
        
    }
}
